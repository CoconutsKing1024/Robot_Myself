{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "STM32F407 Debug (Build + Flash + Debug)",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/Robot_Myself.elf",
      "servertype": "openocd",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      "preLaunchTask": "Build Debug",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw"
    },
    {
      "name": "STM32F407 Attach (Build + Download OpenOCD + Debug)",
      "type": "cortex-debug",
      "request": "attach",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/Robot_Myself.elf",
      "servertype": "openocd",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      "preLaunchTask": "Build + Download",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "raw"
    }
  ]
}
